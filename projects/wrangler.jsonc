/**
 * Internal-воркер `projects` (F3 backend: CRUD проектов; упаковка из pack).
 *
 * - Без публичного `routes` — все запросы только через `notetaker-api-gateway`
 *   (Service Binding `PROJECTS`).
 * - JWT не валидируется здесь (CLAUDE.md → правило 11): доверяем заголовку
 *   `x-user-id`, который ставит gateway после успешной проверки токена.
 * - При удалении проекта и при привязке заметок из from-pack воркер вызывает
 *   `notetaker-notes` через Service Binding `NOTES` для batch-обновления projectId.
 *
 * Полный список правил — `notetaker-back/CLAUDE.md`.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "notetaker-projects",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-09",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"workers_dev": false,
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "notetaker",
			"database_id": "86ba93ac-dfd9-4820-88a6-d6b970828a0d",
			"migrations_dir": "drizzle"
		}
	],
	"services": [
		{
			"binding": "NOTES",
			"service": "notetaker-notes"
		}
	],
	"dev": {
		"port": 8793
	}
}
